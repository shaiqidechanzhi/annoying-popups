{
  "manifest_version": 3,
  "name": "超烦人弹窗整活插件",
  "version": "1.0.0",
  "description": "各种烦人弹窗，视频整活专用。关闭按钮可随时退出。",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "windows",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "烦人弹窗 - 点击设置",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "settings.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}